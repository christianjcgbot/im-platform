		"svelte": "^5.54.0",
		"svelte-check": "^4.4.2",
		"typescript": "^5.9.3",
		"vite": "^7.3.1"
	},
	"dependencies": {
		"@supabase/ssr": "^0.9.0",
		"@supabase/supabase-js": "^2.100.1",
		"@tiptap/core": "^3.21.0",
		"@tiptap/starter-kit": "^3.21.0"
	}
